// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ============================================
// CORE INFRASTRUCTURE - Auth & Multi-Tenancy
// ============================================

model Tenant {
  id       String       @id @default(cuid())
  name     String
  slug     String       @unique
  plan     Plan         @default(STARTER)
  status   TenantStatus @default(ACTIVE)
  settings Json         @default("{}")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  users User[]

  // Notification Relations
  notifications             Notification[]
  notificationPreferences   NotificationPreference[]
  entityWatchers            EntityWatcher[]
  notificationDeliveries    NotificationDelivery[]

  // CRM Relations
  organizations      Organization[]
  persons            Person[]
  pipelines          Pipeline[]
  stages             Stage[]
  deals              Deal[]
  leads              Lead[]
  leadLabels         LeadLabel[]
  dealLabels         DealLabel[]
  dealPermittedUsers DealPermittedUser[]
  activities         Activity[]
  emails             Email[]
  emailAccounts      EmailAccount[]
  fieldDefinitions   FieldDefinition[]
  notes              Note[]

  // UW Relations
  submissions        Submission[]
  quotes             Quote[]

  @@map("tenants")
}

enum Plan {
  STARTER
  PROFESSIONAL
  ENTERPRISE
}

enum TenantStatus {
  ACTIVE
  SUSPENDED
  TRIAL
}

model User {
  id                String  @id @default(cuid())
  supertokensUserId String? @unique // Made nullable to support Stack Auth users
  stackAuthUserId   String? @unique // Stack Auth user ID (for multi-provider support)
  tenantId          String

  email     String // Changed from @unique to allow same email in different tenants
  firstName String?
  lastName  String?
  avatar    String?

  role        UserRole   @default(MEMBER)
  permissions Json       @default("{}")
  status      UserStatus @default(ACTIVE)

  jobTitle   String?
  department String?

  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt
  lastOnline DateTime?

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  // Notification Relations
  notifications             Notification[]
  notificationPreferences   NotificationPreference[]
  entityWatchers            EntityWatcher[]
  notificationDeliveries    NotificationDelivery[]

  // CRM Relations
  ownedDeals         Deal[]              @relation("DealOwner")
  createdDeals       Deal[]              @relation("DealCreator")
  ownedLeads         Lead[]              @relation("LeadOwner")
  createdLeads       Lead[]              @relation("LeadCreator")
  ownedOrganizations Organization[]
  activities         Activity[]
  emails             Email[]
  emailAccounts      EmailAccount[]
  notes              Note[]
  leadPermittedUsers  LeadPermittedUser[]
  dealPermittedUsers  DealPermittedUser[]
  uwSubmissions       Submission[]        @relation("SubmissionUW") // UW module

  @@unique([email, tenantId], name: "user_email_tenant_unique")
  @@index([tenantId])
  @@index([supertokensUserId])
  @@index([stackAuthUserId])
  @@map("users")
}

enum UserRole {
  ADMIN
  MANAGER
  UNDERWRITER
  SALES
  MEMBER
}

enum UserStatus {
  ACTIVE
  INACTIVE
  SUSPENDED
  INVITED
}

// ============================================
// CORE INFRASTRUCTURE - Audit Logging
// ============================================

model AuditLog {
  id        String   @id @default(cuid())
  tenantId  String?
  userId    String?
  action    String // e.g. "USER_INVITED", "DEAL_CREATED", "SETTINGS_UPDATED"
  module    String // e.g. "USERS", "DEALS", "SETTINGS", "AUTH"
  entityId  String? // ID of the affected entity
  entityType String? // e.g. "User", "Deal", "Pipeline"
  details   Json     @default("{}") // Additional context (old/new values, metadata)
  ip        String?
  userAgent String?  @db.Text

  createdAt DateTime @default(now())

  @@index([tenantId, createdAt])
  @@index([tenantId, module])
  @@index([tenantId, action])
  @@index([userId])
  @@index([entityId, entityType])
  @@map("audit_logs")
}

// ============================================
// CORE INFRASTRUCTURE - Notifications
// ============================================

model OutboxEvent {
  id            String       @id @default(cuid())
  tenantId      String
  sourceEventId String
  type          String       // e.g. "crm.activity.assigned"
  actorUserId   String?
  entityKind    String?      // e.g. "activity", "deal", "lead"
  entityId      String?
  payload       Json         @default("{}")
  status        OutboxStatus @default(PENDING)
  attempts      Int          @default(0)
  maxAttempts   Int          @default(5)
  lockedAt      DateTime?
  lastError     String?      @db.Text
  occurredAt    DateTime     @default(now())
  processedAt   DateTime?

  @@unique([tenantId, sourceEventId])
  @@index([status, occurredAt])
  @@index([tenantId, status, occurredAt])
  @@index([type, status])
  @@map("outbox_events")
}

enum OutboxStatus {
  PENDING
  PROCESSING
  PROCESSED
  FAILED
}

model Notification {
  id            String    @id @default(cuid())
  tenantId      String
  userId        String
  type          String    // e.g. "crm.activity.assigned"
  title         String
  body          String    @db.Text
  data          Json      @default("{}") // entity refs, deep-link info
  severity      NotificationSeverity @default(INFO)
  sourceEventId String?
  dedupeKey     String?
  readAt        DateTime?
  archivedAt    DateTime?
  createdAt     DateTime  @default(now())

  tenant    Tenant                 @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  user      User                   @relation(fields: [userId], references: [id], onDelete: Cascade)
  deliveries NotificationDelivery[]

  @@unique([tenantId, userId, sourceEventId])
  @@index([tenantId, userId, createdAt(sort: Desc)])
  @@index([tenantId, userId, readAt])
  @@map("notifications")
}

enum NotificationSeverity {
  INFO
  WARNING
  URGENT
}

model NotificationPreference {
  id               String  @id @default(cuid())
  tenantId         String
  userId           String
  notificationType String  // e.g. "crm.activity.assigned" or "*" for global
  inAppEnabled     Boolean @default(true)
  emailEnabled     Boolean @default(false)
  // v2: digestMode String, quietFrom String, quietTo String, timezone String

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([tenantId, userId, notificationType])
  @@index([tenantId, userId])
  @@map("notification_preferences")
}

model NotificationDelivery {
  id             String         @id @default(cuid())
  tenantId       String
  notificationId String
  userId         String
  channel        String         // 'email' | 'sms' | 'push'
  status         DeliveryStatus @default(PENDING)
  provider       String?        // e.g. 'sendgrid', 'ses', 'smtp'
  providerMsgId  String?        // provider-returned message ID
  attempts       Int            @default(0)
  lastError      String?        @db.Text
  sentAt         DateTime?
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt

  tenant       Tenant       @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  notification Notification @relation(fields: [notificationId], references: [id], onDelete: Cascade)
  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([tenantId, userId, channel])
  @@index([status, createdAt])
  @@index([notificationId])
  @@map("notification_deliveries")
}

enum DeliveryStatus {
  PENDING
  SENDING
  SENT
  FAILED
  SKIPPED
}

model EntityWatcher {
  id         String @id @default(cuid())
  tenantId   String
  entityKind String // "deal", "lead", "organization"
  entityId   String
  userId     String

  createdAt DateTime @default(now())

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([tenantId, entityKind, entityId, userId])
  @@index([tenantId, entityKind, entityId])
  @@index([userId])
  @@map("entity_watchers")
}

// ============================================
// CRM DOMAIN MODELS
// ============================================

// --- Contacts Module ---

model Organization {
  id          String    @id @default(cuid())
  tenantId    String
  name        String
  domain      String? // Normalized email domain (e.g., "acme.com") for auto-linking
  ownerId     String? // Account manager / owner
  address     String?
  countryCode String? // ISO country code (e.g., "CH", "DE", "US")
  city        String?
  industry    String?
  size        String? // e.g., "1-10", "11-50", "51-200", etc.
  website     String?
  phone       String?
  customData  Json      @default("{}")
  // Activity analytics
  lastActivityDate DateTime?
  nextActivityDate DateTime?
  deleted     Boolean   @default(false)
  deletedAt   DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tenant      Tenant       @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  owner       User?        @relation(fields: [ownerId], references: [id], onDelete: SetNull)
  persons     Person[]
  deals       Deal[]
  leads       Lead[]
  activities  Activity[]
  emails      Email[]
  notes       Note[]
  submissions Submission[] // UW module

  @@index([tenantId])
  @@index([tenantId, deleted])
  @@index([tenantId, domain])
  @@index([tenantId, ownerId])
  @@index([tenantId, countryCode])
  @@index([tenantId, city])
  @@map("organizations")
}

model Person {
  id         String    @id @default(cuid())
  tenantId   String
  orgId      String?
  firstName  String
  lastName   String
  email      String?
  phone      String?
  jobTitle   String?
  customData Json      @default("{}")
  // Activity analytics
  lastActivityDate DateTime?
  nextActivityDate DateTime?
  deleted    Boolean   @default(false)
  deletedAt  DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tenant        Tenant        @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  organization  Organization? @relation(fields: [orgId], references: [id], onDelete: SetNull)
  deals         Deal[]
  leads         Lead[]
  activities    Activity[]
  emails        Email[]
  notes         Note[]
  submissions   Submission[]  // UW module

  @@index([tenantId])
  @@index([tenantId, deleted])
  @@index([email])
  @@map("persons")
}

// --- Sales Pipeline Module ---

model Pipeline {
  id        String    @id @default(cuid())
  tenantId  String
  name      String
  isDefault Boolean   @default(false)
  sortOrder Int       @default(0)
  deleted   Boolean   @default(false)
  deletedAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tenant Tenant  @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  stages Stage[]
  deals  Deal[]

  @@index([tenantId])
  @@index([tenantId, isDefault])
  @@index([tenantId, deleted])
  @@map("pipelines")
}

model Stage {
  id          String    @id @default(cuid())
  tenantId    String
  pipelineId  String
  name        String
  probability Decimal   @default(0) @db.Decimal(5, 2) // 0-100
  sortOrder   Int       @default(0)
  isRotten    Boolean   @default(false)
  rottenDays  Int? // Days before deal becomes rotten
  deleted     Boolean   @default(false)
  deletedAt   DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tenant   Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  pipeline Pipeline @relation(fields: [pipelineId], references: [id], onDelete: Cascade)
  deals    Deal[]

  @@index([tenantId])
  @@index([pipelineId, sortOrder])
  @@index([tenantId, deleted])
  @@map("stages")
}

model Deal {
  id                String     @id @default(cuid())
  tenantId          String
  pipelineId        String
  stageId           String
  ownerId           String
  personId          String?
  orgId             String?
  title             String
  value             Decimal    @default(0) @db.Decimal(18, 2)
  currency          String     @default("USD")
  status            DealStatus @default(OPEN)
  expectedCloseDate DateTime?  @db.Date
  wonAt             DateTime?
  lostAt            DateTime?
  lostReason        String?
  customData        Json       @default("{}")
  deleted           Boolean    @default(false)
  deletedAt         DateTime?

  // V2 fields (PR-1)
  creatorId       String?          // Who created the deal
  probability     Int?             // 0-100, manual override of stage probability
  stageChangeTime DateTime?        // When stage was last changed
  firstWonTime    DateTime?        // First time deal was won (for reopen tracking)
  source          String?          // Business source: inbound_call, email, web_form, partner, etc.
  externalSourceId String?         // ID in external system
  visibility      DealVisibility   @default(COMPANY) // Visibility level
  priority        DealPriority?    // Deal priority
  rottenFlag      Boolean          @default(false) // Is deal rotten (stuck too long on stage)
  rottenTime      DateTime?        // When deal became rotten
  renewalType     String?          // one_time, renewal, new_business
  // Activity analytics
  lastActivityDate DateTime?
  nextActivityDate DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tenant             Tenant              @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  pipeline           Pipeline            @relation(fields: [pipelineId], references: [id], onDelete: Restrict)
  stage              Stage               @relation(fields: [stageId], references: [id], onDelete: Restrict)
  owner              User                @relation("DealOwner", fields: [ownerId], references: [id], onDelete: Restrict)
  creator            User?               @relation("DealCreator", fields: [creatorId], references: [id], onDelete: SetNull)
  person             Person?             @relation(fields: [personId], references: [id], onDelete: SetNull)
  organization       Organization?       @relation(fields: [orgId], references: [id], onDelete: SetNull)
  activities         Activity[]
  emails             Email[]
  notes              Note[]
  convertedFromLeads Lead[]
  labelLinks         DealLabelLink[]
  permittedUsers     DealPermittedUser[]

  @@index([tenantId])
  @@index([tenantId, deleted])
  @@index([tenantId, status, expectedCloseDate])
  @@index([pipelineId, stageId])
  @@index([ownerId])
  @@index([creatorId])
  @@index([tenantId, visibility])
  @@index([tenantId, priority])
  @@index([tenantId, source])
  @@index([tenantId, stageChangeTime])
  @@index([tenantId, rottenFlag])
  @@map("deals")
}

// --- Leads Module ---

model Lead {
  id              String         @id @default(uuid())
  tenantId        String
  ownerId         String
  creatorId       String?
  personId        String?
  orgId           String?
  title           String
  description     String?        @db.Text
  source          String? // Business source: Website, Referral, Cold Call, Partner
  origin          String? // Technical origin: API, WebForm, Import, Manual
  inboxChannel    String? // Inbox entry channel: web_form, email_inbox, api, manual
  externalSourceId String? // ID in external system (Facebook Ads, landing, other CRM)
  status          LeadStatus     @default(OPEN)
  valueAmount     Decimal?       @db.Decimal(18, 2)
  valueCurrency   String?        @db.VarChar(3) // ISO currency code
  expectedCloseDate DateTime?    @db.Date
  wasSeen         Boolean?
  visibility      LeadVisibility @default(COMPANY)
  convertedDealId String?
  customData      Json           @default("{}")
  // Activity analytics
  lastActivityDate DateTime?
  nextActivityDate DateTime?
  deleted         Boolean        @default(false)
  deletedAt       DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tenant          Tenant              @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  owner           User                @relation("LeadOwner", fields: [ownerId], references: [id], onDelete: Restrict)
  creator         User?               @relation("LeadCreator", fields: [creatorId], references: [id], onDelete: SetNull)
  person          Person?             @relation(fields: [personId], references: [id], onDelete: SetNull)
  organization    Organization?       @relation(fields: [orgId], references: [id], onDelete: SetNull)
  convertedToDeal Deal?               @relation(fields: [convertedDealId], references: [id], onDelete: SetNull)
  labelLinks      LeadLabelLink[]
  permittedUsers  LeadPermittedUser[]
  notes           Note[]
  activities      Activity[]
  emails          Email[]

  @@index([tenantId])
  @@index([tenantId, status])
  @@index([tenantId, deleted])
  @@index([tenantId, wasSeen])
  @@index([ownerId])
  @@index([creatorId])
  @@map("leads")
}

model LeadLabel {
  id        String  @id @default(uuid())
  tenantId  String
  name      String
  color     String? // Hex color code for UI display
  isSystem  Boolean @default(false) // System labels (hot/warm/cold) can't be deleted

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tenant    Tenant          @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  leadLinks LeadLabelLink[]

  @@unique([tenantId, name])
  @@index([tenantId])
  @@map("lead_labels")
}

model LeadLabelLink {
  leadId  String
  labelId String

  lead  Lead      @relation(fields: [leadId], references: [id], onDelete: Cascade)
  label LeadLabel @relation(fields: [labelId], references: [id], onDelete: Cascade)

  @@id([leadId, labelId])
  @@map("lead_label_links")
}

model LeadPermittedUser {
  id             String @id @default(uuid())
  tenantId       String
  leadId         String
  userId         String
  permissionType String @default("read") // read | write

  createdAt DateTime @default(now())

  lead Lead @relation(fields: [leadId], references: [id], onDelete: Cascade)
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([leadId, userId])
  @@index([tenantId])
  @@index([userId])
  @@map("lead_permitted_users")
}

// --- Deal Labels Module ---

model DealLabel {
  id        String   @id @default(cuid())
  tenantId  String
  name      String
  color     String?  @default("#6B7280")
  isSystem  Boolean  @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tenant    Tenant          @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  dealLinks DealLabelLink[]

  @@unique([tenantId, name])
  @@index([tenantId])
  @@map("deal_labels")
}

model DealLabelLink {
  id        String   @id @default(cuid())
  dealId    String
  labelId   String

  createdAt DateTime @default(now())

  deal  Deal      @relation(fields: [dealId], references: [id], onDelete: Cascade)
  label DealLabel @relation(fields: [labelId], references: [id], onDelete: Cascade)

  @@unique([dealId, labelId])
  @@index([dealId])
  @@index([labelId])
  @@map("deal_label_links")
}

model DealPermittedUser {
  id             String   @id @default(cuid())
  tenantId       String
  dealId         String
  userId         String
  permissionType String   @default("read") // "read" | "write"

  createdAt DateTime @default(now())

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  deal   Deal   @relation(fields: [dealId], references: [id], onDelete: Cascade)
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([dealId, userId])
  @@index([tenantId])
  @@index([dealId])
  @@index([userId])
  @@map("deal_permitted_users")
}

// --- Notes Module ---

model Note {
  id       String  @id @default(uuid())
  tenantId String
  authorId String
  body     String  @db.Text
  pinned   Boolean @default(false)

  leadId   String?
  dealId   String?
  personId String?
  orgId    String?

  deleted   Boolean   @default(false)
  deletedAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tenant       Tenant        @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  author       User          @relation(fields: [authorId], references: [id], onDelete: Restrict)
  lead         Lead?         @relation(fields: [leadId], references: [id], onDelete: Cascade)
  deal         Deal?         @relation(fields: [dealId], references: [id], onDelete: Cascade)
  person       Person?       @relation(fields: [personId], references: [id], onDelete: SetNull)
  organization Organization? @relation(fields: [orgId], references: [id], onDelete: SetNull)

  @@index([tenantId])
  @@index([tenantId, deleted])
  @@index([leadId])
  @@index([dealId])
  @@index([personId])
  @@index([authorId])
  @@map("notes")
}

// --- Activities Module ---

model Activity {
  id          String       @id @default(cuid())
  tenantId    String
  ownerId     String
  type        ActivityType
  subject     String
  dueAt       DateTime?
  hasTime     Boolean      @default(false) // false = all-day, true = specific time in dueAt
  durationMin Int?
  busyFlag    BusyFlag     @default(FREE)
  done        Boolean      @default(false)
  dealId      String?
  leadId      String?
  personId    String?
  orgId       String?
  note        String?      @db.Text
  completedAt DateTime?
  // Calendar sync scaffold
  externalEventId  String?
  calendarProvider String?
  deleted     Boolean      @default(false)
  deletedAt   DateTime?

  // Reminder time: when to fire the DUE_SOON notification.
  // Defaults to dueAt − 1 hour; can be overridden per activity.
  // Reset to null whenever dueAt is changed so a fresh reminder fires.
  remindAt  DateTime?

  // Reminder notification tracking — prevents duplicate due_soon/overdue alerts.
  // Set atomically by the activity-reminder scheduler job.
  // Reset to null when dueAt is rescheduled so reminders re-fire.
  dueSoonNotifiedAt DateTime?
  overdueNotifiedAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tenant       Tenant        @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  owner        User          @relation(fields: [ownerId], references: [id], onDelete: Restrict)
  deal         Deal?         @relation(fields: [dealId], references: [id], onDelete: Cascade)
  lead         Lead?         @relation(fields: [leadId], references: [id], onDelete: Cascade)
  person       Person?       @relation(fields: [personId], references: [id], onDelete: SetNull)
  organization Organization? @relation(fields: [orgId], references: [id], onDelete: SetNull)

  @@index([tenantId])
  @@index([tenantId, done, dueAt])
  @@index([tenantId, ownerId, done, dueAt])
  @@index([tenantId, deleted])
  @@index([tenantId, done, deleted, remindAt, dueSoonNotifiedAt])
  @@index([tenantId, done, deleted, dueAt, overdueNotifiedAt])
  @@index([dealId])
  @@index([leadId])
  @@index([personId])
  @@index([ownerId])
  @@map("activities")
}

// --- Email Module ---

model Email {
  id                    String         @id @default(cuid())
  tenantId              String
  userId                String
  providerAccountId     String?
  direction             EmailDirection
  subject               String
  from                  String
  to                    String
  cc                    String?
  bcc                   String?
  messageId             String         @unique
  inReplyTo             String?
  references            String?        @db.Text
  sentAt                DateTime?
  receivedAt            DateTime?
  bodyPreview           String?        @db.Text
  hasHtmlBody           Boolean        @default(false)
  hasTextBody           Boolean        @default(false)
  threadId              String?
  dealId                String?
  leadId                String?
  personId              String?
  orgId                 String?
  isLinkedAutomatically Boolean        @default(false)
  deleted               Boolean        @default(false)
  deletedAt             DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tenant         Tenant               @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  user           User                 @relation(fields: [userId], references: [id], onDelete: Restrict)
  account        EmailAccount?        @relation(fields: [providerAccountId], references: [id], onDelete: SetNull)
  deal           Deal?                @relation(fields: [dealId], references: [id], onDelete: SetNull)
  lead           Lead?                @relation(fields: [leadId], references: [id], onDelete: Cascade)
  person         Person?              @relation(fields: [personId], references: [id], onDelete: SetNull)
  organization   Organization?        @relation(fields: [orgId], references: [id], onDelete: SetNull)
  trackingEvents EmailTrackingEvent[]

  @@index([tenantId])
  @@index([tenantId, direction])
  @@index([tenantId, deleted])
  @@index([threadId])
  @@index([dealId])
  @@index([leadId])
  @@index([personId])
  @@index([userId])
  @@map("emails")
}

model EmailAccount {
  id           String        @id @default(cuid())
  tenantId     String
  userId       String
  provider     EmailProvider
  imapHost     String?
  imapPort     Int?
  smtpHost     String?
  smtpPort     Int?
  encryption   String? // "SSL", "TLS", "STARTTLS"
  oauthToken   String?       @db.Text // Encrypted OAuth token
  syncFromDate DateTime?     @db.Date
  folders      Json          @default("[]") // Array of folder names to sync
  isActive     Boolean       @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tenant Tenant  @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  user   User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  emails Email[]

  @@index([tenantId])
  @@index([userId])
  @@map("email_accounts")
}

model EmailTrackingEvent {
  id         String            @id @default(cuid())
  emailId    String
  type       TrackingEventType
  occurredAt DateTime          @default(now())
  ip         String?
  userAgent  String?           @db.Text

  email Email @relation(fields: [emailId], references: [id], onDelete: Cascade)

  @@index([emailId])
  @@map("email_tracking_events")
}

// --- Custom Fields Module ---

model FieldDefinition {
  id         String          @id @default(cuid())
  tenantId   String
  entityType FieldEntityType
  key        String // e.g., "industry", "deal_source"
  label      String // e.g., "Industry", "Deal Source"
  fieldType  FieldType
  options    Json? // For SELECT/MULTI_SELECT: ["Option1", "Option2"]
  sortOrder  Int             @default(0)
  deleted    Boolean         @default(false)
  deletedAt  DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([tenantId, entityType, key])
  @@index([tenantId, entityType])
  @@index([tenantId, deleted])
  @@map("field_definitions")
}

